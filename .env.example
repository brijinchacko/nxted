NODE_ENV=development
PORT=3001
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=nxted.ai
NEXT_PUBLIC_BRAND_PARENT=OFORO LTD

# Search-console verification (optional). Paste the token from the HTML-tag
# verification method; the meta tags only render when these are set.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# Show one-click demo logins on /auth/login. Set to "false" to hide them.
NEXT_PUBLIC_SHOW_DEMO_LOGINS=true

# Google Analytics 4 measurement id (defaults to the configured property if unset).
NEXT_PUBLIC_GA_ID=G-MB83TD2F70

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nxted_db

NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=
AUTH_TRUST_HOST=true

OPENROUTER_API_KEY=
